# ============================================================
#  Invoice Reconciliation Agent — Environment Variables
#  Copy this file to .env and fill in your real values:
#    cp .env.example .env
# ============================================================

# ── Environment server ──────────────────────────────────────
# URL where the FastAPI env server is running.
# Use http://localhost:8000 when running locally or via Docker.
ENV_BASE_URL=http://localhost:8000

# ── LLM Provider ────────────────────────────────────────────
# Choose one: together | groq | openai
LLM_PROVIDER=groq

# ── API Key for your chosen provider ────────────────────────
# Together AI → https://api.together.xyz
# Groq        → https://console.groq.com
# OpenAI      → https://platform.openai.com
LLM_API_KEY=your_api_key_here

# ── Model name ───────────────────────────────────────────────
# Together AI  → meta-llama/Llama-3.3-70B-Instruct-Turbo
# Groq         → llama-3.3-70b-versatile
# OpenAI       → gpt-4o
LLM_MODEL=llama-3.3-70b-versatile

# ── (Optional) Docker image name ─────────────────────────────
# Only needed if running the env via Docker image directly.
# IMAGE_NAME=your_hf_username/invoice-processing-env:latest

# Last Audit: 2026-04-12
